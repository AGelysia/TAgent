{
  "id": "worldedit.replace",
  "version": 1,
  "description": "Replace blocks in the player's current WorldEdit selection.",
  "requirements": {
    "plugins": [
      {
        "name": "WorldEdit",
        "version": ">=7.3 <8"
      }
    ]
  },
  "execution": {
    "type": "command",
    "source": "player",
    "commandRoot": "replace",
    "template": "/replace {from} {to}"
  },
  "arguments": {
    "from": {
      "type": "minecraft:block-pattern",
      "description": "Block pattern to replace.",
      "required": true
    },
    "to": {
      "type": "minecraft:block-pattern",
      "description": "Replacement block pattern.",
      "required": true
    }
  },
  "effects": {
    "category": "WRITE_WORLD",
    "scope": "current_selection",
    "maximumBlocks": 100000
  },
  "permissions": {
    "minimum": "OP"
  },
  "confirmation": {
    "required": true
  },
  "reversibility": {
    "type": "capability",
    "capability": "worldedit.undo"
  }
}
