{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://minecraft-agent.dev/schemas/1.0/client-handshake.schema.json",
  "title": "Minecraft Agent Fabric Client Handshake",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "clientProtocolVersion",
    "modVersion",
    "capabilities",
    "dependencies"
  ],
  "properties": {
    "clientProtocolVersion": { "enum": ["1.0", "1.1"] },
    "modVersion": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64,
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(?:[-+][0-9A-Za-z.-]+)?$"
    },
    "capabilities": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "overlay",
        "itemIcons",
        "recipeView",
        "litematicaPreview",
        "litematicaMaterialList"
      ],
      "properties": {
        "overlay": { "type": "integer", "minimum": 0, "maximum": 1 },
        "itemIcons": { "type": "integer", "minimum": 0, "maximum": 1 },
        "recipeView": { "type": "integer", "minimum": 0, "maximum": 2 },
        "litematicaPreview": { "type": "integer", "minimum": 0, "maximum": 1 },
        "litematicaMaterialList": {
          "type": "integer",
          "minimum": 0,
          "maximum": 1
        }
      }
    },
    "dependencies": {
      "type": "object",
      "additionalProperties": false,
      "required": ["litematica", "malilib"],
      "properties": {
        "litematica": { "$ref": "#/$defs/dependencyVersion" },
        "malilib": { "$ref": "#/$defs/dependencyVersion" }
      }
    },
    "diagnostics": {
      "type": "object",
      "additionalProperties": false,
      "required": ["litematicaAdapter"],
      "properties": {
        "litematicaAdapter": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "status",
            "minecraftVersion",
            "fabricLoaderVersion",
            "litematicaVersion",
            "malilibVersion",
            "adapterId"
          ],
          "properties": {
            "status": {
              "enum": [
                "READY",
                "NOT_INSTALLED",
                "MISSING_DEPENDENCY",
                "UNSUPPORTED_VERSION",
                "ADAPTER_LINKAGE_FAILED",
                "PREVIEW_STORAGE_UNAVAILABLE"
              ]
            },
            "minecraftVersion": { "$ref": "#/$defs/version" },
            "fabricLoaderVersion": { "$ref": "#/$defs/version" },
            "litematicaVersion": { "$ref": "#/$defs/dependencyVersion" },
            "malilibVersion": { "$ref": "#/$defs/dependencyVersion" },
            "adapterId": {
              "oneOf": [
                {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 64,
                  "pattern": "^[A-Za-z0-9._-]+$"
                },
                { "type": "null" }
              ]
            }
          },
          "allOf": [
            {
              "if": {
                "properties": {
                  "status": { "enum": ["READY", "ADAPTER_LINKAGE_FAILED"] }
                },
                "required": ["status"]
              },
              "then": {
                "properties": {
                  "litematicaVersion": { "type": "string" },
                  "malilibVersion": { "type": "string" },
                  "adapterId": { "type": "string" }
                }
              }
            },
            {
              "if": {
                "properties": { "status": { "const": "NOT_INSTALLED" } },
                "required": ["status"]
              },
              "then": {
                "properties": {
                  "litematicaVersion": { "type": "null" },
                  "adapterId": { "type": "null" }
                }
              }
            },
            {
              "if": {
                "properties": { "status": { "const": "MISSING_DEPENDENCY" } },
                "required": ["status"]
              },
              "then": {
                "properties": {
                  "litematicaVersion": { "type": "string" },
                  "malilibVersion": { "type": "null" },
                  "adapterId": { "type": "null" }
                }
              }
            },
            {
              "if": {
                "properties": { "status": { "const": "UNSUPPORTED_VERSION" } },
                "required": ["status"]
              },
              "then": {
                "properties": {
                  "litematicaVersion": { "type": "string" },
                  "malilibVersion": { "type": "string" },
                  "adapterId": { "type": "null" }
                }
              }
            },
            {
              "if": {
                "properties": {
                  "status": { "const": "PREVIEW_STORAGE_UNAVAILABLE" }
                },
                "required": ["status"]
              },
              "then": { "properties": { "adapterId": { "type": "null" } } }
            }
          ]
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": { "clientProtocolVersion": { "const": "1.1" } },
        "required": ["clientProtocolVersion"]
      },
      "then": {
        "properties": { "diagnostics": {} },
        "required": ["diagnostics"]
      },
      "else": { "properties": { "diagnostics": false } }
    },
    {
      "if": {
        "properties": {
          "capabilities": {
            "type": "object",
            "properties": { "litematicaPreview": { "const": 1 } },
            "required": ["litematicaPreview"]
          }
        },
        "required": ["capabilities"]
      },
      "then": {
        "properties": {
          "dependencies": {
            "type": "object",
            "properties": {
              "litematica": { "type": "string" },
              "malilib": { "type": "string" }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "capabilities": {
            "type": "object",
            "properties": { "litematicaMaterialList": { "const": 1 } },
            "required": ["litematicaMaterialList"]
          }
        },
        "required": ["capabilities"]
      },
      "then": {
        "properties": {
          "capabilities": {
            "type": "object",
            "properties": { "litematicaPreview": { "const": 1 } }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "clientProtocolVersion": { "const": "1.1" },
          "diagnostics": {
            "type": "object",
            "properties": {
              "litematicaAdapter": {
                "type": "object",
                "properties": { "litematicaVersion": { "type": "string" } },
                "required": ["litematicaVersion"]
              }
            },
            "required": ["litematicaAdapter"]
          }
        },
        "required": ["clientProtocolVersion", "diagnostics"]
      },
      "then": {
        "properties": {
          "dependencies": {
            "type": "object",
            "properties": { "litematica": { "type": "string" } }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "clientProtocolVersion": { "const": "1.1" },
          "diagnostics": {
            "type": "object",
            "properties": {
              "litematicaAdapter": {
                "type": "object",
                "properties": { "litematicaVersion": { "type": "null" } },
                "required": ["litematicaVersion"]
              }
            },
            "required": ["litematicaAdapter"]
          }
        },
        "required": ["clientProtocolVersion", "diagnostics"]
      },
      "then": {
        "properties": {
          "dependencies": {
            "type": "object",
            "properties": { "litematica": { "type": "null" } }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "clientProtocolVersion": { "const": "1.1" },
          "diagnostics": {
            "type": "object",
            "properties": {
              "litematicaAdapter": {
                "type": "object",
                "properties": { "malilibVersion": { "type": "string" } },
                "required": ["malilibVersion"]
              }
            },
            "required": ["litematicaAdapter"]
          }
        },
        "required": ["clientProtocolVersion", "diagnostics"]
      },
      "then": {
        "properties": {
          "dependencies": {
            "type": "object",
            "properties": { "malilib": { "type": "string" } }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "clientProtocolVersion": { "const": "1.1" },
          "diagnostics": {
            "type": "object",
            "properties": {
              "litematicaAdapter": {
                "type": "object",
                "properties": { "malilibVersion": { "type": "null" } },
                "required": ["malilibVersion"]
              }
            },
            "required": ["litematicaAdapter"]
          }
        },
        "required": ["clientProtocolVersion", "diagnostics"]
      },
      "then": {
        "properties": {
          "dependencies": {
            "type": "object",
            "properties": { "malilib": { "type": "null" } }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "clientProtocolVersion": { "const": "1.1" },
          "diagnostics": {
            "type": "object",
            "properties": {
              "litematicaAdapter": {
                "type": "object",
                "properties": {
                  "status": {
                    "enum": [
                      "NOT_INSTALLED",
                      "MISSING_DEPENDENCY",
                      "UNSUPPORTED_VERSION",
                      "ADAPTER_LINKAGE_FAILED",
                      "PREVIEW_STORAGE_UNAVAILABLE"
                    ]
                  }
                },
                "required": ["status"]
              }
            },
            "required": ["litematicaAdapter"]
          }
        },
        "required": ["clientProtocolVersion", "diagnostics"]
      },
      "then": {
        "properties": {
          "capabilities": {
            "type": "object",
            "properties": {
              "litematicaPreview": { "const": 0 },
              "litematicaMaterialList": { "const": 0 }
            }
          }
        }
      }
    }
  ],
  "$defs": {
    "version": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64,
      "pattern": "^[0-9A-Za-z][0-9A-Za-z._+-]{0,63}$"
    },
    "dependencyVersion": {
      "oneOf": [{ "$ref": "#/$defs/version" }, { "type": "null" }]
    }
  }
}
