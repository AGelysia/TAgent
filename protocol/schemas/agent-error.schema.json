{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://minecraft-agent.dev/schemas/1.0/agent-error.schema.json",
  "title": "Minecraft Agent Error Payload",
  "type": "object",
  "additionalProperties": false,
  "required": ["playerUuid", "code", "fallbackText", "retryable"],
  "properties": {
    "playerUuid": {
      "type": "string",
      "format": "uuid"
    },
    "code": {
      "enum": [
        "MODEL_TIMEOUT",
        "MODEL_UNAVAILABLE",
        "MODEL_AUTHENTICATION_FAILED",
        "MODEL_RESPONSE_INVALID",
        "REQUEST_CANCELLED",
        "REQUEST_LIMITED",
        "BUDGET_EXCEEDED",
        "TOOL_REJECTED",
        "TOOL_ROUND_LIMIT",
        "SESSION_NOT_FOUND",
        "CONVERSATION_STORAGE_DISABLED",
        "RUNTIME_INTERNAL_ERROR"
      ]
    },
    "fallbackText": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512
    },
    "retryable": {
      "type": "boolean"
    }
  }
}
