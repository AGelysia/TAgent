{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://minecraft-agent.dev/schemas/1.0/tools/project-list-result.schema.json",
  "title": "Project List Result",
  "type": "object",
  "additionalProperties": false,
  "required": ["projects", "truncated"],
  "properties": {
    "projects": {
      "type": "array",
      "maxItems": 20,
      "items": {
        "$ref": "project-common.schema.json#/$defs/projectSummary"
      }
    },
    "truncated": { "type": "boolean" }
  }
}
