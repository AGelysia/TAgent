{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://minecraft-agent.dev/schemas/1.0/tools/player-held-item-read-result.schema.json",
  "title": "player.held_item.read Result",
  "type": "object",
  "additionalProperties": false,
  "required": ["selectedSlot", "mainHand", "offHand"],
  "properties": {
    "selectedSlot": {
      "type": "integer",
      "minimum": 0,
      "maximum": 8
    },
    "mainHand": {
      "oneOf": [
        {
          "$ref": "common.schema.json#/$defs/itemStack"
        },
        {
          "type": "null"
        }
      ]
    },
    "offHand": {
      "oneOf": [
        {
          "$ref": "common.schema.json#/$defs/itemStack"
        },
        {
          "type": "null"
        }
      ]
    }
  }
}
