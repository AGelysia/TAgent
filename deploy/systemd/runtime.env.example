# Install as /etc/tagent/runtime.env, owned by root with mode 0600.
# Use one provider key only. Never install this file in the Paper service.
MINECRAFT_AGENT_SERVER_TOKEN=replace-with-a-new-64-hex-token

# OPENAI_API_KEY=replace-with-provider-key
# ANTHROPIC_API_KEY=replace-with-provider-key
# DEEPSEEK_API_KEY=replace-with-provider-key
# GEMINI_API_KEY=replace-with-provider-key
# OPENAI_COMPATIBLE_API_KEY=replace-with-provider-key

# Set only when model.baseUrl references the matching whole-value variable.
# OPENAI_BASE_URL=https://api.openai.com/v1
# ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
# OPENAI_COMPATIBLE_BASE_URL=https://reviewed.example.invalid/v1
