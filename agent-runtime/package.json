{
  "name": "minecraft-agent-runtime",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Local runtime for Minecraft Agent",
  "engines": {
    "node": ">=22.16.0 <23",
    "npm": ">=10"
  },
  "exports": "./dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "npm run build --silent && npm start",
    "start": "node dist/bootstrap/index.js",
    "version": "node scripts/version.mjs",
    "test": "vitest run",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "npm run format:check && npm run lint && npm run build && npm test"
  },
  "dependencies": {
    "@fastify/websocket": "11.3.0",
    "ajv": "8.20.0",
    "ajv-formats": "3.0.1",
    "fastify": "5.10.0",
    "yaml": "2.9.0",
    "zod": "4.1.12"
  },
  "devDependencies": {
    "@eslint/js": "9.39.1",
    "@types/node": "22.19.1",
    "@types/ws": "8.18.1",
    "eslint": "9.39.1",
    "eslint-config-prettier": "10.1.8",
    "globals": "16.5.0",
    "prettier": "3.7.4",
    "typescript": "5.9.3",
    "typescript-eslint": "8.48.1",
    "vitest": "4.1.10"
  }
}
