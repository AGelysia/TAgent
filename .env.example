# Local deployment configuration resolves whole-value references at startup.
# This file is documentation only and is not loaded automatically. Do not put real values here.
MINECRAFT_AGENT_SERVER_TOKEN=replace-with-a-random-local-token

# Configure only the API key selected by model.provider.
OPENAI_API_KEY=replace-with-provider-key
ANTHROPIC_API_KEY=replace-with-provider-key
DEEPSEEK_API_KEY=replace-with-provider-key
GEMINI_API_KEY=replace-with-provider-key
OPENAI_COMPATIBLE_API_KEY=replace-with-provider-key

# Optional overrides for official profiles; omit model.baseUrl to use their defaults.
OPENAI_BASE_URL=https://api.openai.com/v1
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
DEEPSEEK_BASE_URL=https://api.deepseek.com
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
# Required when provider is openai-compatible; replace with a reviewed endpoint.
OPENAI_COMPATIBLE_BASE_URL=https://models.example.invalid/v1

# Opt in only after installing the exact supported Fabric/Litematica dependency tuple.
MINECRAFT_AGENT_BUILD_PREVIEW_ENABLED=false
